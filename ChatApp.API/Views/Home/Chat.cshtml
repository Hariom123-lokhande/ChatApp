@{
    ViewData["Title"] = "ChatApp";
}
@using ChatApp.API
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> localizer
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChatApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/chat.css" />
    <script>
        function changeLanguage(lang) {
            const url = new URL(window.location.href);
            url.searchParams.set('culture', lang);
            url.searchParams.set('ui-culture', lang);
            window.location.href = url.href;
        }

        // Inline UI logic for stability
        function switchTab(tab) {
            document.querySelectorAll('.tab').forEach((t, i) =>
                t.classList.toggle('active', tab === 'login' ? i === 0 : i === 1)
            );
            const loginForm = document.getElementById('login-form');
            const registerForm = document.getElementById('register-form');
            if(loginForm) loginForm.classList.toggle('active', tab === 'login');
            if(registerForm) registerForm.classList.toggle('active', tab === 'register');
        }

        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            if (!input) return;
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            const open = btn.querySelector('.eye-open');
            const closed = btn.querySelector('.eye-closed');
            if (open && closed) {
                open.classList.toggle('hidden', isPassword);
                closed.classList.toggle('hidden', !isPassword);
            }
        }
    </script>
</head>
<body>








    <div id="offline-banner" class="offline-banner hidden">📍 Connection unstable... Reconnecting</div>

    <!-- AUTH SCREEN -->
    <div id="auth-screen" class="screen active">
        <div class="language-dropdown-container">
            <select class="language-dropdown" onchange="changeLanguage(this.value)">
                <option value="en" selected="@(currentCulture.StartsWith("en") ? "selected" : null)">English</option>
                <option value="ja" selected="@(currentCulture.StartsWith("ja") ? "selected" : null)">Japanese</option>
            </select>
        </div>
        <div class="auth-container">
            <div class="auth-card">
                <h1>💬 ChatApp</h1>
                
                <div class="auth-tabs">



                    <button id="tab-login" class="tab active" onclick="switchTab('login')">@localizer["SignIn"]</button>
                    <button id="tab-register" class="tab" onclick="switchTab('register')">@localizer["SignUp"]</button>
                
                
                </div>
                <form id="login-form" class="auth-form active" onsubmit="handleLogin(event)">
                    <input type="text" id="login-email" placeholder="Enter Email" required>
                    <div class="auth-field password-wrapper">
                        <input type="password" id="login-password" placeholder="Enter Password" required>
                        <button type="button" class="eye-toggle" onclick="togglePassword('login-password', this)" title="Show/Hide Password">
                            <svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            <svg class="eye-closed hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                        </button>
                    </div>
                    <button type="submit" class="btn-primary">@localizer["GetStarted"]</button>
                </form>
                <form id="register-form" class="auth-form" onsubmit="handleRegister(event)">
                    <input type="text" id="reg-username" placeholder="Display Name" required>
                    <input type="email" id="reg-email" placeholder="Email Address" required>
                    <div class="auth-field password-wrapper">
                        <input type="password" id="reg-password" placeholder="Strong Password (e.g. Abc@123)" required minlength="6" title="Needs 6+ chars, 1 uppercase, 1 number, 1 special char">
                        <button type="button" class="eye-toggle" onclick="togglePassword('reg-password', this)" title="Show/Hide Password">
                            <svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            <svg class="eye-closed hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                        </button>
                    </div>
                    <button type="submit" class="btn-primary">Create Account</button>
                </form>
                <div id="auth-msg" class="msg hidden"></div>
            </div>
        </div>
    </div>

    <!-- CHAT SCREEN (High-End Dashboard) -->
    <div id="chat-screen" class="screen">
        
        <!-- 1. Activity Bar (Ultra Left) -->
        <nav class="activity-bar">
            <div class="activity-icon active" title="Conversations" onclick="switchPanel('users')">💬</div>
            <div class="activity-icon" title="Community Groups" onclick="switchPanel('groups')">👥</div>
           <!-- <div class="activity-icon" title="Global Search">🌎</div>-->
            <!--<div style="margin-top: auto;" class="activity-icon" title="User Settings">⚙️</div>-->
            <div id="theme-toggle" class="activity-icon" onclick="toggleTheme()" title="Toggle Theme">🌙</div>
            <div class="activity-icon" onclick="logout()" title="Secure Logout" style="color: #ff4d4d;">
                <img src="data:image/png;base64,"
                     width="20" height="20" />
        </nav>

        <!-- 2. Sidebar (Nav Pane) -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <h2>@localizer["Messages"]</h2>
                    <select class="language-dropdown" onchange="changeLanguage(this.value)" style="padding: 6px 28px 6px 10px; font-size: 12px; border-radius: 8px; width: auto; min-width: 90px;">
                        <option value="en" selected="@(currentCulture.StartsWith("en") ? "selected" : null)">English</option>
                        <option value="ja" selected="@(currentCulture.StartsWith("ja") ? "selected" : null)">Japanese</option>
                    </select>
                </div>
                <div id="display-name" style="font-size: 13px; font-weight: 700; color: var(--primary); margin-top: 6px; letter-spacing: 0.5px;"></div>
            </div>

            <div class="search-box">
                <span class="search-icon">🔍</span>



                    <input type="text" id="chat-search" placeholder="@localizer["Search"]" />
      
                    

            </div>

            <div class="sidebar-tabs">
                <button id="stab-users" class="stab active" onclick="switchPanel('users')">Personal</button>
                <button id="stab-groups" class="stab" onclick="switchPanel('groups')">Groups</button>
            </div>

            <div id="users-panel" class="panel active">
                <div id="users-list" class="list"></div>
            </div>

            <div id="groups-panel" class="panel">
                <div class="group-create" style="padding: 0 24px 16px;">
                    <div style="display:flex; gap:8px; background:rgba(255,255,255,0.03); padding:8px; border-radius:12px; border:1px solid var(--border);">
                        <input type="text" id="new-group-name" placeholder="Create group..." style="flex:1; font-size:13px; color:var(--text-main);">
                        <button onclick="createGroup()" style="color: var(--primary); font-size: 20px; cursor:pointer; background:none;">+</button>
                    </div>
                </div>
                <div id="groups-list" class="list"></div>
            </div>
        </aside>

        <!-- 3. Main Chat View (Core) -->
        <main class="chat-main">
            <!-- Empty View -->
            <div id="no-chat" class="empty-state">
                <div style="font-size: 80px; margin-bottom: 24px; filter: drop-shadow(0 0 10px var(--primary-glow));">✨</div>
                <h2 style="font-size: 24px; font-weight: 800; margin-bottom: 12px;">Start a Conversation</h2>
                <p style="color: var(--text-dim); max-width: 300px;">Choose a contact from the sidebar to begin your encrypted messaging session.</p>
            </div>

            <!-- Active Chat View -->
            <div id="active-chat" class="chat-view hidden">
                <header class="chat-header glass-panel">
                    <div class="avatar" id="header-avatar" onclick="toggleDetails()" style="background: linear-gradient(45deg, #8b5cf6, #3b82f6); color:#fff; cursor:pointer;">?</div>
                    <div style="flex: 1;">
                        <h3 id="chat-title">Secure Chat</h3>
                        <div class="chat-status" id="chat-status-text">Active Now</div>
                    </div>
                    <div style="display:flex; gap:10px;">
                        <button id="add-member-btn" class="action-icon hidden" onclick="promptAddMember()" title="Add Member">👤+</button>
                        <button class="action-icon" title="Call User">📞</button>
                      
                           
                            <button class="action-icon" onclick="toggleDetails()" title="Chat Info">
                                <img src="https://cdn-icons-png.flaticon.com/128/6576/6576064.png"
                                     alt="info"
                                     width="20"
                                     height="20">
                            </button>
                    </div>
                </header>

                <div id="typing-indicator" class="hidden" style="padding: 12px 32px; font-size: 13px; color: var(--accent-cyan); font-weight: 600;">
                    typing...
                </div>

                <div class="messages-area" id="messages-area">
                    <div class="messages-container" id="messages">
                        <!-- Content Injected -->
                    </div>
                </div>

                <div class="input-area">
                    <div class="input-card">
                        <button class="action-icon" title="Attachment">📎</button>
                        <textarea id="msg-input" placeholder="Type your message here..." rows="1"></textarea>
                        <button class="action-icon" title="Choose Emoji">😊</button>
                        <button onclick="sendMessage()" id="send-btn" class="action-icon send-icon">➤</button>
                    </div>
                </div>
            </div>
        </main>

        <!-- 4. Info Panel (Right) -->
        <aside id="details-panel" class="details-panel glass-panel">
            <div id="details-content" style="display:flex; flex-direction:column; height:100%;">
                <div style="padding: 32px; text-align:center; border-bottom: 1px solid var(--border);">
                    <div class="avatar" id="details-avatar" style="width: 80px; height: 80px; margin: 0 auto 16px; font-size: 28px; border-radius: 24px; background: var(--primary);">?</div>
                    <h3 id="details-title" style="font-size: 18px; margin-bottom: 4px;">User Details</h3>
                    <p id="details-status" style="color: var(--text-dim); font-size: 13px;">Status: Offline</p>
                </div>
                
                <div id="group-members-section" class="hidden" style="flex:1; display:flex; flex-direction:column; min-height:0;">
                    <div style="padding: 20px 24px; display:flex; justify-content:space-between; align-items:center;">
                        <span style="font-size: 12px; font-weight: 800; color: var(--primary); letter-spacing: 1px;">GROUP MEMBERS</span>
                        <button id="details-add-btn" class="action-icon" onclick="promptAddMember()" title="Add Member" style="font-size:16px;">👤+</button>
                    </div>
                    <div id="members-list" style="flex:1; overflow-y:auto; padding: 0 24px 24px;">
                        <!-- Members injected -->
                    </div>
                </div>

                <div id="user-info-section" style="padding: 24px;">
                    <p style="font-size: 12px; color: var(--text-dim); margin-bottom: 12px; font-weight: 800;">SHARED MEDIA</p>
                    <div style="background: rgba(255,255,255,0.02); padding: 16px; border-radius: 12px; text-align:center; color: var(--text-dim); font-size: 13px; border: 1px dashed var(--border);">
                        No files shared yet
                    </div>
                </div>
            </div>
        </aside>
    </div>


    <!-- MODAL SYSTEM -->
    <div id="modal-overlay" class="modal-overlay hidden">
        <div class="modal-card">
            <h3 id="modal-title" style="margin-bottom: 15px;">ChatApp</h3>
            <p id="modal-msg" style="color: var(--text-muted); margin-bottom: 25px; line-height: 1.6;"></p>
            <div id="modal-prompt-div" class="hidden" style="margin-bottom: 25px;">
                <input type="text" id="modal-input" placeholder="Type here..." 
                       style="width: 100%; padding: 12px; background: #f1f5f9; border-radius: 12px; border: 1px solid var(--border-color);">
            </div>
            <div class="modal-btns" style="display: flex; gap: 10px; justify-content: center;">
                <button id="modal-cancel" class="btn-sec hidden" onclick="closeModal(false)" 
                        style="padding: 10px 20px; background: #f1f5f9; border-radius: 10px; cursor: pointer;">Cancel</button>
                <button id="modal-ok" class="btn-primary" onclick="closeModal(true)" 
                        style="min-width: 100px; margin-top: 0;">Confirm</button>
            </div>
        </div>
    </div>


    <!-- SignalR CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <!-- Chat Logic -->
    <script type="module" src="~/js/main.js"></script>

</body>
</html>
